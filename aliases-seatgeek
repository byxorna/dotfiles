export LG_REPOSITORY_ROOT_PATH="$HOME/code/src/gitlab.seatgeekadmin.com"
export GOPROXY="https://goproxy.ingress.seatgeek.mgmt"
export GOPRIVATE="gitlab.seatgeekadmin.com,github.com/seatgeek"
export GONOPROXY="none"

if [[ -d $LG_REPOSITORY_ROOT_PATH ]] ; then
  function sg() {
    d="$(find $LG_REPOSITORY_ROOT_PATH -type d -name .git -maxdepth 3|xargs dirname |fzf --query="$1" --preview="git -C {} log HEAD -1")"
    if [[ -d $d ]] ; then
      pushd "$d"
    fi
  }

  export VOLTA_HOME="$HOME/.volta"
  export PATH="$PATH:$VOLTA_HOME/bin"
  export PATH="$PATH:~/.letsgo/bin"
fi

gitlab-mr-ci-logs(){
  project="${1}"
  mr="${2}"
  # todo: find only those matching a specific MR (or pipeline or stage)
  echo "fetching logs for $project MR$mr CI runners" >&2
  # TODO look up latest pipeline for an MR
  # ci.seatgeek.io/pipeline-id=111111
  # ci.seatgeek.io/stage=deploy
  set -x
  kubectl --context=seatgeek:us-136-mgmt-default:okta logs -n gitlab-ci -l "ci.seatgeek.io/project-slug=${project//\//-}" -f
}

nucleus-atlantis-terraform-logs() {
  mr="${1}"
  f="~/tmp/$(date -I)-nucleus-atlantis-mr-762-terraform.log"
  s_f="/atlantis/repos/platform/nucleus/$mr/default/terraform.log"
  t="platform-nucleus-atlantis/nucleus-atlantis-0"
  echo "Pulling $s_f from $t..." >&2
  kubectl cp "$t:$s_f" "$f" -c app
  echo "Fetched file: $f" >&2
}

# cleanup, reset, refresh sg work laptop
sg-clean() {
  echo "❱ sg-clean" >&2
  cd ~
  brew update && brew upgrade && brew upgrade --cask
  for p in platform/platform-operator ; do
    pushd "./code/src/gitlab.seatgeekadmin.com/${p}"
    echo "$p: $(git branch --show-current)"
    popd
  done
  letsgo login
}
